{
  "$schema": "https://schemas.tokens.studio/",
  "$metadata": {
    "name": "SaniSostenible 2.0",
    "description": "Design tokens para el prototipo I3M 2026-1 · RISC Ingeniería S.A.S",
    "version": "1.0.0",
    "author": "RISC Ingeniería S.A.S",
    "contest": "Concurso I3M 2026-1 · Universidad Santo Tomás Tunja",
    "tokenSetsOrder": ["global", "color", "typography", "spacing", "radius", "shadow", "component"]
  },
  "global": {
    "fontFamily": {
      "primary": {
        "value": "Poppins",
        "type": "fontFamilies",
        "description": "Fuente principal — importar desde Google Fonts"
      },
      "fallback": {
        "value": "system-ui, -apple-system, sans-serif",
        "type": "fontFamilies"
      }
    },
    "frame": {
      "width":  { "value": "390", "type": "sizing", "description": "Ancho del frame móvil (iPhone 14 Pro)" },
      "height": { "value": "844", "type": "sizing", "description": "Alto del frame móvil (iPhone 14 Pro)" }
    }
  },
  "color": {
    "primary": {
      "900": { "value": "#1B5E20", "type": "color", "description": "Verde profundo — hero, splash, headers" },
      "700": { "value": "#2E7D32", "type": "color", "description": "Verde principal — botones primarios, íconos activos" },
      "500": { "value": "#4CAF50", "type": "color", "description": "Verde medio — progress bars, accents" },
      "100": { "value": "#C8E6C9", "type": "color", "description": "Verde claro — badges, bordes suaves" },
      "50":  { "value": "#E8F5E9", "type": "color", "description": "Verde muy claro — backgrounds de cards, hover states" }
    },
    "status": {
      "warning":       { "value": "#F9A825", "type": "color", "description": "Amarillo — estado ATENCIÓN" },
      "warningLight":  { "value": "#FFF8E1", "type": "color", "description": "Amarillo claro — fondo estado ATENCIÓN" },
      "error":         { "value": "#C62828", "type": "color", "description": "Rojo — estado URGENTE" },
      "errorLight":    { "value": "#FFEBEE", "type": "color", "description": "Rojo claro — fondo estado URGENTE" },
      "success":       { "value": "#2E7D32", "type": "color", "description": "Verde — estado ÓPTIMO" },
      "successLight":  { "value": "#E8F5E9", "type": "color", "description": "Verde claro — fondo estado ÓPTIMO" }
    },
    "water": {
      "blue":      { "value": "#0277BD", "type": "color", "description": "Azul agua — ODS banner, campos infiltración" },
      "blueLight": { "value": "#E1F5FE", "type": "color", "description": "Azul muy claro — fondos módulo agua" }
    },
    "neutral": {
      "black":  { "value": "#212121", "type": "color", "description": "Negro principal — títulos" },
      "gray700": { "value": "#616161", "type": "color", "description": "Gris oscuro — subtítulos, body" },
      "gray400": { "value": "#9E9E9E", "type": "color", "description": "Gris medio — placeholders, disabled" },
      "gray100": { "value": "#F5F5F5", "type": "color", "description": "Gris muy claro — backgrounds, separadores" },
      "white":   { "value": "#FFFFFF", "type": "color", "description": "Blanco puro — cards, overlays" }
    },
    "background": {
      "app":     { "value": "#F0F4F0", "type": "color", "description": "Fondo global de la aplicación" },
      "screen":  { "value": "#1a1a2e", "type": "color", "description": "Fondo del device frame (demo)" }
    },
    "whatsapp": { "value": "#25D366", "type": "color", "description": "Verde WhatsApp — botón CTA contacto" }
  },
  "typography": {
    "h1": {
      "fontFamily":  { "value": "{global.fontFamily.primary}", "type": "fontFamilies" },
      "fontWeight":  { "value": "800", "type": "fontWeights" },
      "fontSize":    { "value": "24", "type": "fontSizes" },
      "lineHeight":  { "value": "32", "type": "lineHeights" },
      "description": "Título principal — Splash, secciones hero"
    },
    "h2": {
      "fontFamily":  { "value": "{global.fontFamily.primary}", "type": "fontFamilies" },
      "fontWeight":  { "value": "700", "type": "fontWeights" },
      "fontSize":    { "value": "20", "type": "fontSizes" },
      "lineHeight":  { "value": "28", "type": "lineHeights" },
      "description": "Título de pantalla — Onboarding, resultados"
    },
    "h3": {
      "fontFamily":  { "value": "{global.fontFamily.primary}", "type": "fontFamilies" },
      "fontWeight":  { "value": "600", "type": "fontWeights" },
      "fontSize":    { "value": "16", "type": "fontSizes" },
      "lineHeight":  { "value": "24", "type": "lineHeights" },
      "description": "Subtítulo de sección — inner headers"
    },
    "bodyRegular": {
      "fontFamily":  { "value": "{global.fontFamily.primary}", "type": "fontFamilies" },
      "fontWeight":  { "value": "400", "type": "fontWeights" },
      "fontSize":    { "value": "14", "type": "fontSizes" },
      "lineHeight":  { "value": "20", "type": "lineHeights" },
      "description": "Cuerpo de texto principal"
    },
    "bodyMedium": {
      "fontFamily":  { "value": "{global.fontFamily.primary}", "type": "fontFamilies" },
      "fontWeight":  { "value": "500", "type": "fontWeights" },
      "fontSize":    { "value": "14", "type": "fontSizes" },
      "lineHeight":  { "value": "20", "type": "lineHeights" },
      "description": "Cuerpo de texto énfasis"
    },
    "button": {
      "fontFamily":  { "value": "{global.fontFamily.primary}", "type": "fontFamilies" },
      "fontWeight":  { "value": "600", "type": "fontWeights" },
      "fontSize":    { "value": "14", "type": "fontSizes" },
      "lineHeight":  { "value": "20", "type": "lineHeights" },
      "description": "Texto de botones"
    },
    "caption": {
      "fontFamily":  { "value": "{global.fontFamily.primary}", "type": "fontFamilies" },
      "fontWeight":  { "value": "300", "type": "fontWeights" },
      "fontSize":    { "value": "12", "type": "fontSizes" },
      "lineHeight":  { "value": "16", "type": "lineHeights" },
      "description": "Etiquetas pequeñas, hints, nav labels"
    },
    "label": {
      "fontFamily":  { "value": "{global.fontFamily.primary}", "type": "fontFamilies" },
      "fontWeight":  { "value": "600", "type": "fontWeights" },
      "fontSize":    { "value": "11", "type": "fontSizes" },
      "lineHeight":  { "value": "14", "type": "lineHeights" },
      "description": "Etiquetas de nav, badges pequeños"
    }
  },
  "spacing": {
    "xs":  { "value": "4",  "type": "spacing" },
    "sm":  { "value": "8",  "type": "spacing" },
    "md":  { "value": "12", "type": "spacing" },
    "lg":  { "value": "16", "type": "spacing" },
    "xl":  { "value": "20", "type": "spacing" },
    "2xl": { "value": "24", "type": "spacing" },
    "3xl": { "value": "32", "type": "spacing" },
    "4xl": { "value": "48", "type": "spacing" },
    "description": "Todos los espaciados son múltiplos de 4px — sistema de 8pt grid"
  },
  "radius": {
    "none": { "value": "0",  "type": "borderRadius" },
    "sm":   { "value": "8",  "type": "borderRadius", "description": "Botones, badges" },
    "md":   { "value": "10", "type": "borderRadius", "description": "Cards compactas, opciones" },
    "lg":   { "value": "16", "type": "borderRadius", "description": "Cards principales" },
    "xl":   { "value": "24", "type": "borderRadius", "description": "Result cards, modales" },
    "full": { "value": "9999", "type": "borderRadius", "description": "Pills, badges redondeados" }
  },
  "shadow": {
    "sm": {
      "value": "0 2px 12px rgba(0,0,0,0.08)",
      "type": "boxShadow",
      "description": "Sombra sutil — cards de lista"
    },
    "md": {
      "value": "0 4px 20px rgba(0,0,0,0.12)",
      "type": "boxShadow",
      "description": "Sombra media — cards destacadas"
    },
    "lg": {
      "value": "0 8px 32px rgba(0,0,0,0.16)",
      "type": "boxShadow",
      "description": "Sombra fuerte — modales, panels"
    },
    "primaryGlow": {
      "value": "0 4px 14px rgba(46,125,50,0.30)",
      "type": "boxShadow",
      "description": "Glow verde — botones primarios"
    },
    "whatsappGlow": {
      "value": "0 4px 14px rgba(37,211,102,0.30)",
      "type": "boxShadow",
      "description": "Glow WhatsApp — botón CTA WhatsApp"
    }
  },
  "component": {
    "button": {
      "primary": {
        "background":  { "value": "{color.primary.700}", "type": "color" },
        "text":        { "value": "{color.neutral.white}", "type": "color" },
        "radius":      { "value": "{radius.md}", "type": "borderRadius" },
        "paddingV":    { "value": "16", "type": "spacing" },
        "paddingH":    { "value": "16", "type": "spacing" },
        "height":      { "value": "52", "type": "sizing" },
        "shadow":      { "value": "{shadow.primaryGlow}", "type": "boxShadow" },
        "font":        { "value": "{typography.button}", "type": "typography" }
      },
      "whatsapp": {
        "background":  { "value": "{color.whatsapp}", "type": "color" },
        "text":        { "value": "{color.neutral.white}", "type": "color" },
        "radius":      { "value": "{radius.md}", "type": "borderRadius" },
        "height":      { "value": "52", "type": "sizing" },
        "shadow":      { "value": "{shadow.whatsappGlow}", "type": "boxShadow" }
      },
      "outline": {
        "background":  { "value": "transparent", "type": "color" },
        "border":      { "value": "{color.primary.700}", "type": "color" },
        "borderWidth": { "value": "2", "type": "borderWidth" },
        "text":        { "value": "{color.primary.700}", "type": "color" },
        "radius":      { "value": "{radius.md}", "type": "borderRadius" },
        "height":      { "value": "52", "type": "sizing" }
      },
      "ghost": {
        "background":  { "value": "transparent", "type": "color" },
        "text":        { "value": "{color.neutral.gray700}", "type": "color" },
        "height":      { "value": "44", "type": "sizing" }
      }
    },
    "card": {
      "default": {
        "background":  { "value": "{color.neutral.white}", "type": "color" },
        "radius":      { "value": "{radius.lg}", "type": "borderRadius" },
        "padding":     { "value": "{spacing.lg}", "type": "spacing" },
        "shadow":      { "value": "{shadow.sm}", "type": "boxShadow" },
        "border":      { "value": "{color.neutral.gray100}", "type": "color" },
        "borderWidth": { "value": "1", "type": "borderWidth" }
      },
      "resultGreen": {
        "background": { "value": "{color.primary.50}", "type": "color" },
        "radius":     { "value": "{radius.xl}", "type": "borderRadius" },
        "padding":    { "value": "{spacing.2xl}", "type": "spacing" },
        "shadow":     { "value": "{shadow.md}", "type": "boxShadow" }
      },
      "resultYellow": {
        "background": { "value": "{color.status.warningLight}", "type": "color" },
        "radius":     { "value": "{radius.xl}", "type": "borderRadius" },
        "padding":    { "value": "{spacing.2xl}", "type": "spacing" },
        "shadow":     { "value": "{shadow.md}", "type": "boxShadow" }
      },
      "resultRed": {
        "background": { "value": "{color.status.errorLight}", "type": "color" },
        "radius":     { "value": "{radius.xl}", "type": "borderRadius" },
        "padding":    { "value": "{spacing.2xl}", "type": "spacing" },
        "shadow":     { "value": "{shadow.md}", "type": "boxShadow" }
      }
    },
    "badge": {
      "free": {
        "background": { "value": "{color.primary.50}", "type": "color" },
        "text":       { "value": "{color.primary.700}", "type": "color" },
        "radius":     { "value": "{radius.full}", "type": "borderRadius" },
        "paddingV":   { "value": "3", "type": "spacing" },
        "paddingH":   { "value": "10", "type": "spacing" },
        "fontSize":   { "value": "11", "type": "fontSizes" }
      },
      "new": {
        "background": { "value": "{color.status.warning}", "type": "color" },
        "text":       { "value": "{color.neutral.black}", "type": "color" },
        "radius":     { "value": "6", "type": "borderRadius" },
        "paddingV":   { "value": "2", "type": "spacing" },
        "paddingH":   { "value": "5", "type": "spacing" },
        "fontSize":   { "value": "8", "type": "fontSizes" }
      },
      "statusOk": {
        "background": { "value": "{color.primary.50}", "type": "color" },
        "text":       { "value": "{color.primary.700}", "type": "color" },
        "border":     { "value": "{color.primary.700}", "type": "color" },
        "radius":     { "value": "{radius.full}", "type": "borderRadius" }
      },
      "statusWarn": {
        "background": { "value": "{color.status.warningLight}", "type": "color" },
        "text":       { "value": "#E65100", "type": "color" },
        "border":     { "value": "{color.status.warning}", "type": "color" },
        "radius":     { "value": "{radius.full}", "type": "borderRadius" }
      },
      "statusErr": {
        "background": { "value": "{color.status.errorLight}", "type": "color" },
        "text":       { "value": "{color.status.error}", "type": "color" },
        "border":     { "value": "{color.status.error}", "type": "color" },
        "radius":     { "value": "{radius.full}", "type": "borderRadius" }
      }
    },
    "icon": {
      "size": {
        "sm": { "value": "20", "type": "sizing" },
        "md": { "value": "24", "type": "sizing" },
        "lg": { "value": "32", "type": "sizing" },
        "xl": { "value": "44", "type": "sizing" }
      },
      "wrap": {
        "size":   { "value": "44", "type": "sizing" },
        "radius": { "value": "14", "type": "borderRadius" }
      },
      "colors": {
        "diag":  { "value": "{color.primary.50}", "type": "color" },
        "eco":   { "value": "#E0F2F1", "type": "color" },
        "guide": { "value": "{color.water.blueLight}", "type": "color" },
        "calc":  { "value": "{color.status.warningLight}", "type": "color" },
        "serv":  { "value": "#EDE7F6", "type": "color" },
        "wa":    { "value": "{color.primary.50}", "type": "color" }
      }
    },
    "nav": {
      "height":          { "value": "64", "type": "sizing" },
      "background":      { "value": "{color.neutral.white}", "type": "color" },
      "borderColor":     { "value": "{color.primary.100}", "type": "color" },
      "activeColor":     { "value": "{color.primary.700}", "type": "color" },
      "inactiveColor":   { "value": "{color.neutral.gray400}", "type": "color" },
      "centerBg":        { "value": "{color.primary.700}", "type": "color" },
      "centerRadius":    { "value": "16", "type": "borderRadius" }
    },
    "progressBar": {
      "height":   { "value": "4", "type": "sizing" },
      "radius":   { "value": "2", "type": "borderRadius" },
      "track":    { "value": "{color.neutral.gray100}", "type": "color" },
      "fill":     { "value": "{color.primary.500}", "type": "color" }
    },
    "stepDot": {
      "size":           { "value": "28", "type": "sizing" },
      "radius":         { "value": "{radius.full}", "type": "borderRadius" },
      "activeBg":       { "value": "{color.primary.700}", "type": "color" },
      "activeText":     { "value": "{color.neutral.white}", "type": "color" },
      "doneBg":         { "value": "{color.primary.100}", "type": "color" },
      "doneText":       { "value": "{color.primary.700}", "type": "color" },
      "pendingBg":      { "value": "{color.neutral.gray100}", "type": "color" },
      "pendingText":    { "value": "{color.neutral.gray400}", "type": "color" }
    },
    "innerHeader": {
      "background":    { "value": "{color.neutral.white}", "type": "color" },
      "borderColor":   { "value": "{color.neutral.gray100}", "type": "color" },
      "height":        { "value": "56", "type": "sizing" },
      "paddingH":      { "value": "{spacing.lg}", "type": "spacing" }
    },
    "backButton": {
      "size":       { "value": "36", "type": "sizing" },
      "radius":     { "value": "10", "type": "borderRadius" },
      "background": { "value": "{color.neutral.gray100}", "type": "color" },
      "fontSize":   { "value": "18", "type": "fontSizes" }
    }
  }
}
