            { "type": "text",  "name": "subtitle","content": "por RISC Ingeniería S.A.S", "x": 0, "y": 440, "width": 390, "align": "center", "style": "Caption", "color": "rgba(255,255,255,0.8)" },
            { "type": "dots",  "name": "loading-dots", "x": 173, "y": 490, "count": 3, "size": 8, "gap": 8, "activeColor": "#FFFFFF", "inactiveColor": "rgba(255,255,255,0.4)" },
            { "type": "text",  "name": "badge-contest", "content": "🏆 Concurso I3M 2026-1", "x": 0, "y": 770, "width": 390, "align": "center", "color": "rgba(255,255,255,0.7)", "fontSize": 11 },
            { "type": "text",  "name": "badge-uni",     "content": "Universidad Santo Tomás · Tunja", "x": 0, "y": 786, "width": 390, "align": "center", "color": "rgba(255,255,255,0.5)", "fontSize": 10 }
