          "height": 1200,
          "background": "#F0F4F0",
          "components": [
            {
              "name": "Button/Primary",
              "variants": ["Default", "Hover", "Pressed", "Loading", "Disabled"],
              "width": "full-width",
              "height": 52,
              "radius": 10,
              "background": "#2E7D32",
              "textColor": "#FFFFFF",
              "shadow": "0 4px 14px rgba(46,125,50,0.30)"
            },
            {
              "name": "Button/WhatsApp",
              "width": "full-width",
              "height": 52,
              "radius": 10,
              "background": "#25D366",
              "textColor": "#FFFFFF"
            },
            {
              "name": "Button/Outline",
              "width": "full-width",
              "height": 52,
              "radius": 10,
              "background": "transparent",
              "border": "#2E7D32",
              "borderWidth": 2,
              "textColor": "#2E7D32"
            },
            {
              "name": "Card/Default",
              "width": "calc(100% - 32px)",
