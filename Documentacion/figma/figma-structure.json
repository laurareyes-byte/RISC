              "paddingV": 6,
              "paddingH": 16,
              "fontSize": 12,
              "fontWeight": 700
            },
            {
              "name": "ProgressBar",
              "height": 4,
              "radius": 2,
              "trackColor": "#F5F5F5",
              "fillColor": "#4CAF50"
