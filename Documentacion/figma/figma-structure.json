            { "name": "Body/Medium-14", "font": "Poppins", "weight": "500", "size": 14, "lineHeight": 20, "usage": "Cuerpo con énfasis" },
            { "name": "Button/SemiBold-14","font": "Poppins", "weight": "600", "size": 14, "lineHeight": 20, "usage": "Labels de botones" },
            { "name": "Caption/Light-12","font": "Poppins", "weight": "300", "size": 12, "lineHeight": 16, "usage": "Hints, nav labels, badges" },
            { "name": "Label/SemiBold-11","font": "Poppins", "weight": "600", "size": 11, "lineHeight": 14, "usage": "Tags pequeños, nav labels" }
