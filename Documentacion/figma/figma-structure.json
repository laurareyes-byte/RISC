              "radius": 9999,
              "paddingV": 3,
              "paddingH": 10,
              "fontSize": 11
            },
            {
              "name": "Badge/NEW",
              "background": "#F9A825",
              "textColor": "#212121",
              "radius": 6,
              "fontSize": 8,
              "position": "absolute top-right"
            },
            {
              "name": "StatusBadge",
              "variants": [
                { "label": "OK",        "bg": "#E8F5E9", "text": "#2E7D32", "border": "#2E7D32" },
                { "label": "ATENCIÓN",  "bg": "#FFF8E1", "text": "#E65100", "border": "#F9A825" },
                { "label": "URGENTE",   "bg": "#FFEBEE", "text": "#C62828", "border": "#C62828" }
