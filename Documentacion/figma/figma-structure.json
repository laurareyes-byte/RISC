    {
      "id": "page-wireframes",
      "name": "📐 Wireframes Lo-Fi",
      "frames": [
        { "id": "wf-splash",       "name": "WF-01 Splash",              "screen": "splash",            "connections": ["wf-onboarding-1"] },
        { "id": "wf-onboarding-1", "name": "WF-02 Onboarding 1/3",      "screen": "onboarding-1",      "connections": ["wf-onboarding-2"] },
        { "id": "wf-onboarding-2", "name": "WF-03 Onboarding 2/3",      "screen": "onboarding-2",      "connections": ["wf-onboarding-3"] },
        { "id": "wf-onboarding-3", "name": "WF-04 Onboarding 3/3",      "screen": "onboarding-3",      "connections": ["wf-home"] },
        { "id": "wf-home",         "name": "WF-05 Home / Dashboard",     "screen": "home",              "connections": ["wf-diagnostico", "wf-ecocompost", "wf-guias", "wf-calc", "wf-servicios"] },
        { "id": "wf-diagnostico",  "name": "WF-06 Diagnóstico Selección","screen": "diagnostico",       "connections": ["wf-diag-preguntas"] },
        { "id": "wf-diag-p1",      "name": "WF-07 Diag Pregunta 1/3",   "screen": "diag-preguntas",    "connections": ["wf-diag-p2"] },
        { "id": "wf-diag-p2",      "name": "WF-08 Diag Pregunta 2/3",   "screen": "diag-preguntas",    "connections": ["wf-diag-p3"] },
        { "id": "wf-diag-p3",      "name": "WF-09 Diag Pregunta 3/3",   "screen": "diag-preguntas",    "connections": ["wf-diag-resultado-verde", "wf-diag-resultado-amarillo", "wf-diag-resultado-rojo"] },
        { "id": "wf-diag-resultado-verde",    "name": "WF-10a Resultado 🟢 Óptimo",   "screen": "diag-resultado", "connections": ["wf-ecocompost", "wf-diagnostico"] },
        { "id": "wf-diag-resultado-amarillo", "name": "WF-10b Resultado 🟡 Atención", "screen": "diag-resultado", "connections": ["wf-ecocompost", "wf-diagnostico"] },
        { "id": "wf-diag-resultado-rojo",     "name": "WF-10c Resultado 🔴 Urgente",  "screen": "diag-resultado", "connections": ["wf-ecocompost", "wf-diagnostico"] },
        { "id": "wf-ecocompost",     "name": "WF-11 Eco-Compost Entrada",   "screen": "ecocompost",       "connections": ["wf-eco-diagnostico", "wf-eco-protocolo", "wf-eco-compostera", "wf-eco-calendario"] },
        { "id": "wf-eco-diagnostico","name": "WF-12 Eco Diagnóstico Lodo",  "screen": "eco-diagnostico",  "connections": ["wf-eco-resultado"] },
        { "id": "wf-eco-resultado",  "name": "WF-13 Eco Resultado",          "screen": "eco-resultado",    "connections": ["wf-eco-protocolo", "wf-eco-calendario"] },
        { "id": "wf-eco-protocolo",  "name": "WF-14 Eco Protocolo",          "screen": "eco-protocolo",    "connections": ["wf-eco-compostera"] },
        { "id": "wf-eco-compostera", "name": "WF-15 Eco Compostera",         "screen": "eco-compostera",   "connections": ["wf-eco-calendario"] },
        { "id": "wf-eco-calendario", "name": "WF-16 Eco Calendario 12 sem",  "screen": "eco-calendario",   "connections": ["wf-ecocompost"] }
      ]
    },
    {
      "id": "page-hifi",
      "name": "📱 Prototipo Hi-Fi",
      "description": "Frames de alta fidelidad — conectados en modo Prototipo de Figma",
      "prototypeConnections": [
        { "from": "splash",             "to": "onboarding-1",           "trigger": "after-delay", "delay": 2800, "animation": "smart-animate", "duration": 300 },
        { "from": "onboarding-1",       "to": "onboarding-2",           "trigger": "on-click",    "element": "btn-siguiente",   "animation": "smart-animate", "duration": 300 },
        { "from": "onboarding-2",       "to": "onboarding-3",           "trigger": "on-click",    "element": "btn-siguiente",   "animation": "smart-animate", "duration": 300 },
        { "from": "onboarding-3",       "to": "home",                   "trigger": "on-click",    "element": "btn-comenzar",    "animation": "smart-animate", "duration": 350 },
        { "from": "home",               "to": "diagnostico",            "trigger": "on-click",    "element": "btn-diagnostico", "animation": "push-left", "duration": 300 },
        { "from": "home",               "to": "ecocompost",             "trigger": "on-click",    "element": "btn-ecocompost",  "animation": "push-left", "duration": 300 },
        { "from": "diagnostico",        "to": "diag-preguntas",         "trigger": "on-click",    "element": "comp-card",       "animation": "push-left", "duration": 300 },
        { "from": "diag-preguntas",     "to": "diag-resultado-verde",   "trigger": "on-click",    "element": "btn-next-green",  "animation": "smart-animate", "duration": 400 },
        { "from": "diag-preguntas",     "to": "diag-resultado-yellow",  "trigger": "on-click",    "element": "btn-next-yellow", "animation": "smart-animate", "duration": 400 },
        { "from": "diag-preguntas",     "to": "diag-resultado-red",     "trigger": "on-click",    "element": "btn-next-red",    "animation": "smart-animate", "duration": 400 },
        { "from": "diag-resultado",     "to": "ecocompost",             "trigger": "on-click",    "element": "btn-eco",         "animation": "push-left", "duration": 300 },
        { "from": "diag-resultado",     "to": "diagnostico",            "trigger": "on-click",    "element": "btn-retry",       "animation": "push-right", "duration": 280 },
        { "from": "ecocompost",         "to": "eco-diagnostico",        "trigger": "on-click",    "element": "stage-01",        "animation": "push-left", "duration": 300 },
        { "from": "ecocompost",         "to": "eco-protocolo",          "trigger": "on-click",    "element": "stage-02",        "animation": "push-left", "duration": 300 },
        { "from": "ecocompost",         "to": "eco-compostera",         "trigger": "on-click",    "element": "stage-03",        "animation": "push-left", "duration": 300 },
        { "from": "ecocompost",         "to": "eco-calendario",         "trigger": "on-click",    "element": "stage-04",        "animation": "push-left", "duration": 300 },
        { "from": "eco-diagnostico",    "to": "eco-resultado",          "trigger": "on-click",    "element": "btn-evaluar",     "animation": "smart-animate", "duration": 400 },
        { "from": "eco-resultado",      "to": "eco-protocolo",          "trigger": "on-click",    "element": "btn-protocolo",   "animation": "push-left", "duration": 300 },
        { "from": "eco-protocolo",      "to": "eco-compostera",         "trigger": "on-click",    "element": "btn-compostera",  "animation": "push-left", "duration": 300 },
        { "from": "eco-compostera",     "to": "eco-calendario",         "trigger": "on-click",    "element": "btn-calendario",  "animation": "push-left", "duration": 300 },
        {
          "note": "BACK BUTTONS — Todos los botones ← usan animation: push-right, duration: 280ms",
          "backConnections": [
            { "from": "diagnostico",    "back-to": "home" },
            { "from": "diag-preguntas", "back-to": "diagnostico" },
            { "from": "diag-resultado", "back-to": "diagnostico" },
            { "from": "ecocompost",     "back-to": "home" },
            { "from": "eco-diagnostico","back-to": "ecocompost" },
            { "from": "eco-resultado",  "back-to": "eco-diagnostico" },
            { "from": "eco-protocolo",  "back-to": "ecocompost" },
            { "from": "eco-compostera", "back-to": "ecocompost" },
            { "from": "eco-calendario", "back-to": "ecocompost" }
          ]
        }
      ],
      "frames": [
        {
          "id": "splash",
