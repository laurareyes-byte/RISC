              "name": "StepDot",
              "size": 28,
              "states": {
                "active":  { "bg": "#2E7D32", "text": "#FFFFFF" },
                "done":    { "bg": "#C8E6C9", "text": "#2E7D32" },
                "pending": { "bg": "#F5F5F5", "text": "#9E9E9E" }
              }
            },
            {
              "name": "InnerHeader",
              "width": 390,
              "height": 56,
              "background": "#FFFFFF",
              "borderBottom": "#F5F5F5",
              "sticky": true,
              "elements": ["BackButton (36x36px, radius 10)", "Title (H3)", "RightSlot (pill/label)"]
            },
            {
              "name": "IconWrap",
              "size": 44,
              "radius": 14,
              "backgroundVariants": {
                "diag":  "#E8F5E9",
                "eco":   "#E0F2F1",
                "guide": "#E1F5FE",
                "calc":  "#FFF8E1",
                "serv":  "#EDE7F6",
                "wa":    "#E8F5E9"
              }
            },
